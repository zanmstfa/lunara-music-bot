{
  "name": "lunara-music-bot",
  "version": "1.0.0",
  "description": "Bot musik Discord full JavaScript dengan mood radio, vote skip, kontrol tombol, dan antrean pintar.",
  "type": "module",
  "main": "src/index.js",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "deploy": "node src/deploy-commands.js",
    "check": "node scripts/check-syntax.js && node --test"
  },
  "keywords": [
    "discord",
    "music-bot",
    "discord.js",
    "javascript"
  ],
  "license": "MIT",
  "dependencies": {
    "@discord-player/extractor": "7.2.0",
    "@snazzah/davey": "0.1.12",
    "discord-player": "7.2.0",
    "discord-player-youtubei": "2.0.0",
    "discord.js": "14.27.0",
    "dotenv": "17.4.2",
    "ffmpeg-static": "5.3.0",
    "opusscript": "0.1.1",
    "youtube-dl-exec": "3.1.9"
  }
}
